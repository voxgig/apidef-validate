# Entity: remove

main: kit: entity: remove: {

  alias: field: {}

  fields: [
    {
      name: "username"
      req: true
      type: "`$ARRAY`"
    }
  ]

  name: "remove"
  op: {
    create: {
      name: "create"
      points: [
        {
          args: {
            params: [
              {
                kind: "param"
                name: "enterprise"
                orig: "enterprise"
                reqd: true
                type: "`$STRING`"
              }
              {
                kind: "param"
                name: "team_id"
                orig: "enterprise_team"
                reqd: true
                type: "`$STRING`"
              }
            ]
          }
          method: "POST"
          orig: "/enterprises/{enterprise}/teams/{enterprise-team}/memberships/remove"
          parts: [
            "enterprises"
            "{enterprise}"
            "teams"
            "{team_id}"
            "memberships"
            "remove"
          ]
          rename: {
            param: {
              "enterprise-team": "team_id"
            }
          }
          select: {
            exist: [
              "enterprise"
              "team_id"
            ]
          }
          transform: {
            req: "`reqdata`"
            res: "`body`"
          }
        }
      ]
    }
  }

  relations: {
    ancestors: [
      [
        "enterpris"
        "team"
      ]
    ]
  }



}