# Entity: interaction

main: kit: entity: interaction: {

  alias: field: {}

  fields: [
    {
      name: "expires_at"
      req: false
      type: "`$STRING`"
    }
    {
      name: "limit"
      req: false
      type: "`$STRING`"
    }
    {
