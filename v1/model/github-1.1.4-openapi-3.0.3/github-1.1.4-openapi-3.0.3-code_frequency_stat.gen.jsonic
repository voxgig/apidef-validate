# Entity: code_frequency_stat

main: kit: entity: code_frequency_stat: {

  alias: field: {}

  id: {
    field: "id"
    name: "id"
  }

  name: "code_frequency_stat"
  op: {
    list: {
      name: "list"
      targets: [
        {
          args: {
            params: [
              {
                kind: "param"
                name: "owner"
                orig: "owner"
                reqd: true
                type: "`$STRING`"
              }
              {
                kind: "param"
                name: "repo"
                orig: "repo"
                reqd: true
                type: "`$STRING`"
              }
            ]
          }
          method: "GET"
          orig: "/repos/{owner}/{repo}/stats/punch_card"
          parts: [
            "repos"
            "{owner}"
            "{repo}"
            "stats"
            "punch_card"
          ]
          select: {
            exist: [
              "owner"
              "repo"
            ]
          }
          transform: {
            req: "`reqdata`"
            res: "`body`"
          }
        }
      ]
    }
  }

  relations: {
    ancestors: [
      [
        "repos"
        "{owner}"
      ]
    ]
  }



}