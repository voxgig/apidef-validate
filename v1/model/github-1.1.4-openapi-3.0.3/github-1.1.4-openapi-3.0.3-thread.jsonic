# Entity: thread

main: kit: entity: thread: {

  alias: field: {}

  fields: [
    {
      name: "id"
      req: true
      type: "`$STRING`"
    }
    {
      name: "last_read_at"
      req: true
      type: "`$STRING`"
    }
    {
      name: "reason"
      req: true
      type: "`$STRING`"
    }
    {
      name: "repository"
      req: true
