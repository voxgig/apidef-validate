  }

  name: "emoji"
  op: {
    load: {
      name: "load"
      targets: [
        {
          method: "GET"
          orig: "/emojis"
          parts: [
            "emojis"
          ]
          transform: {
            req: "`reqdata`"
            res: "`body`"
          }
        }
      ]
    }
  }



