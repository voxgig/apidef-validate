                reqd: true
                type: "`$STRING`"
              }
              {
                kind: "param"
                name: "repo"
                orig: "repo"
                reqd: true
                type: "`$STRING`"
              }
            ]
          }
          method: "POST"
          orig: "/repos/{owner}/{repo}/security-advisories/{ghsa_id}/forks"
          parts: [
            "repos"
            "{owner}"
            "{repo}"
            "security-advisories"
            "{id}"
            "forks"
          ]
          rename: {
            param: {
              ghsa_id: "id"
            }
          }
          select: {
            "$action": "fork"
            exist: [
              "id"
              "owner"
              "repo"
            ]
          }
          transform: {
            req: "`reqdata`"
            res: "`body`"
