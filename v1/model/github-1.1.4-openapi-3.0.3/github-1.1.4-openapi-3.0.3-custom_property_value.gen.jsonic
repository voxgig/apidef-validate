# Entity: custom_property_value

main: kit: entity: custom_property_value: {

  alias: field: {}

  fields: [
    {
      name: "property_name"
      req: true
      type: "`$STRING`"
    }
    {
      name: "value"
      req: true
      type: "`$ANY`"
    }
  ]

  id: {
    field: "id"
    name: "id"
  }

  name: "custom_property_value"
  op: {
    list: {
      name: "list"
      points: [
        {
          args: {
            params: [
              {
                kind: "param"
                name: "owner"
                orig: "owner"
                reqd: true
                type: "`$STRING`"
              }
              {
                kind: "param"
                name: "repo"
                orig: "repo"
                reqd: true
                type: "`$STRING`"
              }
            ]
          }
          method: "GET"
          orig: "/repos/{owner}/{repo}/properties/values"
          parts: [
            "repos"
            "{owner}"
            "{repo}"
            "properties"
            "values"
          ]
          select: {
            exist: [
              "owner"
              "repo"
            ]
          }
          transform: {
            req: "`reqdata`"
            res: "`body`"
          }
        }
      ]
    }
  }

  relations: {
    ancestors: [
      [
        "repos"
        "{owner}"
      ]
    ]
  }



}