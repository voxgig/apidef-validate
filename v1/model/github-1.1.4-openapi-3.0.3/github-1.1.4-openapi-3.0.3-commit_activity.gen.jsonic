# Entity: commit_activity

main: kit: entity: commit_activity: {

  alias: field: {}

  fields: [
    {
      name: "day"
      req: true
      type: "`$ARRAY`"
    }
    {
      name: "total"
      req: true
      type: "`$INTEGER`"
    }
    {
      name: "week"
      req: true
      type: "`$INTEGER`"
    }
  ]

  id: {
    field: "id"
    name: "id"
  }

  name: "commit_activity"
  op: {
    list: {
      name: "list"
      points: [
        {
          args: {
            params: [
              {
                kind: "param"
                name: "owner"
                orig: "owner"
                reqd: true
                type: "`$STRING`"
              }
              {
                kind: "param"
                name: "repo"
                orig: "repo"
                reqd: true
                type: "`$STRING`"
              }
            ]
          }
          method: "GET"
          orig: "/repos/{owner}/{repo}/stats/commit_activity"
          parts: [
            "repos"
            "{owner}"
            "{repo}"
            "stats"
            "commit_activity"
          ]
          select: {
            exist: [
              "owner"
              "repo"
            ]
          }
          transform: {
            req: "`reqdata`"
            res: "`body`"
          }
        }
      ]
    }
  }

  relations: {
    ancestors: [
      [
        "repos"
        "{owner}"
      ]
    ]
  }



}