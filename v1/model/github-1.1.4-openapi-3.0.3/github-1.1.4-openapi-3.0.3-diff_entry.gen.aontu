# Entity: diff_entry

main: kit: entity: diff_entry: {

  alias: field: {}

  fields: [
    {
      name: "addition"
      req: true
      type: "`$INTEGER`"
    }
    {
      name: "blob_url"
      req: true
      type: "`$STRING`"
    }
    {
      name: "change"
      req: true
      type: "`$INTEGER`"
    }
    {
      name: "contents_url"
      req: true
      type: "`$STRING`"
    }
    {
      name: "deletion"
      req: true
      type: "`$INTEGER`"
    }
    {
      name: "filename"
      req: true
      type: "`$STRING`"
    }
    {
      name: "patch"
