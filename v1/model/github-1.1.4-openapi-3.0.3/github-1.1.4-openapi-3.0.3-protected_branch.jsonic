# Entity: protected_branch

main: kit: entity: protected_branch: {

  alias: field: {}

  fields: [
    {
      name: "allow_deletion"
      op: {
        update: {
          req: false
          type: "`$BOOLEAN`"
        }
      }
      req: true
      type: "`$OBJECT`"
    }
    {
      name: "allow_force_push"
      op: {
        update: {
          req: false
          type: "`$BOOLEAN`"
        }
      }
      req: true
      type: "`$OBJECT`"
    }
    {
      name: "allow_fork_syncing"
      req: false
      type: "`$OBJECT`"
    }
    {
      name: "block_creation"
      op: {
        update: {
          req: false
          type: "`$BOOLEAN`"
        }
      }
      req: true
      type: "`$OBJECT`"
    }
    {
      name: "enforce_admin"
      req: true
      type: "`$OBJECT`"
    }
    {
      name: "lock_branch"
      req: false
      type: "`$OBJECT`"
    }
    {
      name: "required_conversation_resolution"
      req: false
      type: "`$OBJECT`"
    }
    {
      name: "required_linear_history"
      op: {
        update: {
