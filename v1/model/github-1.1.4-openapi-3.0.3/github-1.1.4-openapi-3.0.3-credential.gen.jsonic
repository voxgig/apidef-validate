# Entity: credential

main: kit: entity: credential: {

  alias: field: {}

  fields: [
    {
      name: "credential"
      req: true
      type: "`$ARRAY`"
    }
  ]

  id: {
    field: "id"
    name: "id"
  }

  name: "credential"
  op: {
    create: {
      name: "create"
      targets: [
        {
          method: "POST"
          orig: "/credentials/revoke"
          parts: [
            "credentials"
            "revoke"
          ]
          select: {
            "$action": "revoke"
          }
          transform: {
            req: "`reqdata`"
            res: "`body`"
          }
        }
      ]
    }
  }



}