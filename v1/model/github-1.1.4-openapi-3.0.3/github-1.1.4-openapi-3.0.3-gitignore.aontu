# Entity: gitignore

main: kit: entity: gitignore: {

  alias: field: {}

  name: "gitignore"
  op: {
    list: {
      name: "list"
      points: [
        {
          method: "GET"
          orig: "/gitignore/templates"
          parts: [
            "gitignore"
            "templates"
          ]
          select: {
            "$action": "template"
          }
          transform: {
            req: "`reqdata`"
            res: "`body`"
          }
        }
      ]
    }
  }



}